<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?><?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.rabitah.frontend.controller.ShellController" styleClass="page">
 <top><HBox spacing="16" styleClass="topbar"><Label text="Rabitah" styleClass="brand-small"/><Label text="campus platform build 3.1" styleClass="build-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="welcome"/><Button text="Log out" onAction="#logout"/></HBox></top>
 <center><TabPane tabClosingPolicy="UNAVAILABLE" styleClass="platform-tabs">
  <tabs>
   <Tab text="Social Feed"><BorderPane><top><VBox spacing="8" styleClass="toolbar"><TextArea fx:id="postText" promptText="Share a campus update..." prefRowCount="2"/><HBox spacing="8"><Button text="Publish post" onAction="#createPost"/><Button text="Refresh" onAction="#refreshFeed"/><Label fx:id="feedStatus" styleClass="muted"/></HBox></VBox></top><center><SplitPane orientation="VERTICAL" dividerPositions="0.55"><ListView fx:id="feedList"/><VBox spacing="6" styleClass="toolbar"><HBox spacing="8"><Label text="Discussion" styleClass="section-title"/><Label fx:id="replyTarget" text="Select a post to see comments" styleClass="muted"/><Region HBox.hgrow="ALWAYS"/><Button text="Refresh comments" onAction="#refreshComments"/></HBox><ListView fx:id="commentList" VBox.vgrow="ALWAYS"/><HBox spacing="8"><Button text="Like comment" onAction="#likeComment"/><Button text="Dislike comment" onAction="#dislikeComment"/><Button text="Reply" onAction="#replyToComment"/><Button text="Cancel reply" onAction="#cancelReply"/></HBox></VBox></SplitPane></center><bottom><HBox spacing="8" styleClass="toolbar"><Button text="Like post" onAction="#likePost"/><Button text="Dislike post" onAction="#dislikePost"/><TextField fx:id="commentText" promptText="Write a comment or reply" HBox.hgrow="ALWAYS"/><Button text="Post comment" onAction="#commentPost"/></HBox></bottom></BorderPane></Tab>
   <Tab text="Notice Board"><BorderPane><top><VBox spacing="8" styleClass="toolbar"><HBox spacing="8"><TextField fx:id="noticeTitle" promptText="Notice title" HBox.hgrow="ALWAYS"/><ComboBox fx:id="noticeType" promptText="Type"/><Button fx:id="publishNoticeButton" text="Publish" onAction="#publishNotice"/></HBox><TextArea fx:id="noticeBody" promptText="Official notice body" prefRowCount="2"/><Button text="Refresh notices" onAction="#refreshNotices"/></VBox></top><center><ListView fx:id="noticeList"/></center></BorderPane></Tab>
   <Tab text="Question Repository"><BorderPane><top><VBox spacing="8" styleClass="toolbar"><HBox spacing="8"><ComboBox fx:id="courseBox" promptText="Course" prefWidth="330"/><TextField fx:id="paperTitle" promptText="Paper title" HBox.hgrow="ALWAYS"/><TextField fx:id="examYear" promptText="Exam year" prefWidth="100"/><Button fx:id="uploadPaperButton" text="Upload PDF" onAction="#uploadPaper"/></HBox><HBox spacing="8"><TextField fx:id="paperSearch" promptText="Search course or paper" HBox.hgrow="ALWAYS"/><Button text="Search" onAction="#refreshPapers"/><Button text="Download PDF" onAction="#downloadPaper"/></HBox><Label fx:id="paperStatus" text="Select a paper, then click Download PDF." styleClass="muted"/></VBox></top><center><ListView fx:id="paperList"/></center></BorderPane></Tab>
   <Tab text="Private Chat"><BorderPane><top><HBox spacing="8" styleClass="toolbar"><ComboBox fx:id="chatUserBox" promptText="Choose a user" prefWidth="320"/><Button text="Open conversation" onAction="#openConversation"/><Label fx:id="chatWith" styleClass="field-label"/></HBox></top><center><ListView fx:id="messageList"/></center><bottom><HBox spacing="8" styleClass="toolbar"><TextField fx:id="messageText" promptText="Type a private message" HBox.hgrow="ALWAYS"/><Button text="Send" onAction="#sendMessage"/></HBox></bottom></BorderPane></Tab>
   <Tab text="Community"><BorderPane><top><HBox spacing="8" styleClass="toolbar"><Label fx:id="communityName" styleClass="section-title"/><Button text="Refresh" onAction="#refreshCommunity"/></HBox></top><center><ListView fx:id="communityList"/></center><bottom><Label text="Community rooms are read-only for students; moderators publish official announcements." styleClass="muted" BorderPane.alignment="CENTER"/></bottom></BorderPane></Tab>
   <Tab fx:id="approvalsTab" text="Admin Approvals"><ScrollPane fitToWidth="true"><content><VBox spacing="10" styleClass="toolbar"><HBox spacing="8"><Label text="Approval inbox" styleClass="section-title"/><Label fx:id="approvalSummary" styleClass="muted"/><Region HBox.hgrow="ALWAYS"/><Button text="Refresh inbox now" onAction="#refreshApprovals"/></HBox><Label text="This inbox updates automatically every 2 seconds." styleClass="muted"/><TextField fx:id="decisionReason" promptText="Optional reason for declining"/><TitledPane text="Student access requests" expanded="true"><content><VBox spacing="6"><ListView fx:id="userApprovalList" prefHeight="150"/><HBox spacing="8"><Button text="Approve student" onAction="#approveUser"/><Button text="Decline student" onAction="#rejectUser"/></HBox></VBox></content></TitledPane><TitledPane text="Pending posts" expanded="true"><content><VBox spacing="6"><ListView fx:id="postApprovalList" prefHeight="150"/><HBox spacing="8"><Button text="Approve post" onAction="#approvePost"/><Button text="Decline post" onAction="#rejectPost"/></HBox></VBox></content></TitledPane><TitledPane text="Pending question papers" expanded="true"><content><VBox spacing="6"><ListView fx:id="paperApprovalList" prefHeight="150"/><HBox spacing="8"><Button text="Approve PDF" onAction="#approvePaper"/><Button text="Decline PDF" onAction="#rejectPaper"/></HBox></VBox></content></TitledPane></VBox></content></ScrollPane></Tab>
   <Tab text="My Profile"><VBox spacing="14" styleClass="content-card"><Label text="My Profile" styleClass="section-title"/><Label fx:id="profileDetails" wrapText="true"/></VBox></Tab>
  </tabs>
 </TabPane></center>
</BorderPane>
